{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bubo.app/buboskin.schema.json",
  "title": "Bubo Skin",
  "description": "A skin theme file for the Bubo calendar app.",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "author",
    "accentColor",
    "surfaceTint",
    "surfaceTintOpacity",
    "backgroundGradient",
    "previewColors",
    "prefersDarkTint"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "minLength": 1,
      "description": "Unique identifier (lowercase_snake_case). Permanent after release."
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "description": "Display name shown in the skin picker."
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Author name or @github_handle."
    },
    "accentColor": {
      "$ref": "#/$defs/color",
      "description": "Primary accent color for buttons, highlights, and tint."
    },
    "surfaceTint": {
      "$ref": "#/$defs/color",
      "description": "Subtle color overlaid on surfaces to set the skin's mood."
    },
    "surfaceTintOpacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Opacity of the surface tint overlay (0 = none, 0.2\u20130.4 = typical)."
    },
    "backgroundGradient": {
      "$ref": "#/$defs/gradient",
      "description": "Background gradient specification."
    },
    "previewColors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/color"
      },
      "minItems": 1,
      "maxItems": 2,
      "description": "1\u20132 colors for the skin picker thumbnail."
    },
    "prefersDarkTint": {
      "type": "boolean",
      "description": "Whether this skin has a dark-tinted mood."
    },
    "secondaryAccent": {
      "$ref": "#/$defs/color",
      "description": "Optional secondary accent for button gradients."
    },
    "buttonStyle": {
      "type": "string",
      "enum": [
        "solid",
        "gradient",
        "glass"
      ],
      "default": "gradient",
      "description": "Button fill style."
    },
    "buttonShape": {
      "type": "string",
      "enum": [
        "capsule",
        "roundedRect",
        "rectangle"
      ],
      "default": "capsule",
      "description": "Button clip shape."
    },
    "buttonColor": {
      "$ref": "#/$defs/color",
      "description": "Explicit foreground color for primary buttons."
    },
    "buttonMaterial": {
      "$ref": "#/$defs/material",
      "default": "regular",
      "description": "Material for glass-style and secondary buttons."
    },
    "buttonTint": {
      "$ref": "#/$defs/color",
      "description": "Color overlay on button material (glass-style)."
    },
    "buttonTintOpacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.3,
      "description": "Opacity of the button tint overlay."
    },
    "toolbarTint": {
      "$ref": "#/$defs/color",
      "description": "Tint color for toolbar buttons (Refresh, Settings, Quit)."
    },
    "barMaterial": {
      "$ref": "#/$defs/material",
      "default": "thick",
      "description": "Material for header and footer bars."
    },
    "barTint": {
      "$ref": "#/$defs/color",
      "description": "Color overlay on top of bar material."
    },
    "barTintOpacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0,
      "description": "Opacity of the bar tint overlay."
    },
    "platterMaterial": {
      "$ref": "#/$defs/material",
      "default": "regular",
      "description": "Material for card/platter surfaces."
    },
    "platterTint": {
      "$ref": "#/$defs/color",
      "description": "Color overlay on platter surfaces."
    },
    "platterTintOpacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0,
      "description": "Opacity of the platter tint overlay."
    },
    "cornerRadius": {
      "type": "number",
      "minimum": 2,
      "maximum": 24,
      "default": 12,
      "description": "Global corner radius for card/platter surfaces (2–24)."
    },
    "shadowOpacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 0.25,
      "default": 0.06,
      "description": "Ambient shadow opacity for elevated surfaces (0–0.25)."
    },
    "shadowRadius": {
      "type": "number",
      "minimum": 0,
      "maximum": 20,
      "default": 8,
      "description": "Ambient shadow blur radius (0–20)."
    },
    "shadowY": {
      "type": "number",
      "default": 4,
      "description": "Vertical offset for the ambient shadow."
    },
    "platterBorderOpacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0,
      "description": "Opacity of a 1px intrinsic inner border (glass highlight)."
    },
    "fontDesign": {
      "type": "string",
      "enum": [
        "default",
        "rounded"
      ],
      "default": "rounded",
      "description": "System font design."
    },
    "fontWeight": {
      "$ref": "#/$defs/fontWeight",
      "default": "semibold",
      "description": "Font weight for body text and buttons."
    },
    "headlineFontWeight": {
      "$ref": "#/$defs/fontWeight",
      "default": "semibold",
      "description": "Font weight for section headers / headlines."
    },
    "sfSymbolRendering": {
      "type": "string",
      "enum": [
        "monochrome",
        "hierarchical",
        "palette",
        "multicolor"
      ],
      "default": "hierarchical",
      "description": "SF Symbol rendering mode."
    },
    "sfSymbolWeight": {
      "type": "string",
      "enum": [
        "ultraLight",
        "thin",
        "light",
        "regular",
        "medium",
        "semibold",
        "bold",
        "heavy",
        "black"
      ],
      "default": "medium",
      "description": "SF Symbol weight."
    },
    "badgeStyle": {
      "type": "string",
      "enum": [
        "filled",
        "outlined",
        "tinted"
      ],
      "default": "tinted",
      "description": "Badge/pill appearance style."
    },
    "separatorStyle": {
      "type": "string",
      "enum": [
        "system",
        "subtle",
        "accent",
        "none"
      ],
      "default": "system",
      "description": "Separator/divider appearance style."
    },
    "separatorOpacity": {
      "type": "number",
      "minimum": 0.05,
      "maximum": 0.5,
      "default": 0.5,
      "description": "Separator opacity (0.05–0.5). Floor at 0.15 when separatorStyle != none."
    },
    "textPrimary": {
      "$ref": "#/$defs/color",
      "description": "Semantic text primary color override. Falls back to system label color."
    },
    "textSecondary": {
      "$ref": "#/$defs/color",
      "description": "Semantic text secondary color override. Falls back to system secondary label."
    },
    "textTertiary": {
      "$ref": "#/$defs/color",
      "description": "Semantic text tertiary color override. Falls back to system tertiary label."
    },
    "destructiveColor": {
      "$ref": "#/$defs/color",
      "description": "Color for destructive actions (delete, remove). Falls back to system red."
    },
    "successColor": {
      "$ref": "#/$defs/color",
      "description": "Color for success states (confirmed, saved). Falls back to system green."
    },
    "warningColor": {
      "$ref": "#/$defs/color",
      "description": "Color for warning states (conflicts, alerts). Falls back to system orange."
    },
    "animationStyle": {
      "type": "string",
      "enum": [
        "bouncy",
        "smooth",
        "snappy"
      ],
      "description": "Animation physics style"
    },
    "hoverShadowOpacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "hoverShadowRadius": {
      "type": "number",
      "minimum": 0
    },
    "hoverShadowY": {
      "type": "number"
    },
    "hoverFillOpacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?|[a-zA-Z]+(:([0-9]*\\.?[0-9]+))?)$",
      "description": "Hex (#RRGGBB or #RRGGBBAA), named (accentColor), named:opacity (accentColor:0.5), or keyword (clear, white, black, gray).",
      "examples": [
        "#0070FA",
        "#0070FA80",
        "accentColor",
        "accentColor:0.5",
        "clear"
      ]
    },
    "material": {
      "type": "string",
      "enum": [
        "ultraThin",
        "thin",
        "regular",
        "thick",
        "ultraThick",
        "bar"
      ],
      "description": "SwiftUI Material level controlling translucency."
    },
    "fontWeight": {
      "type": "string",
      "enum": [
        "regular",
        "medium",
        "semibold",
        "bold"
      ],
      "description": "Font weight."
    },
    "gradient": {
      "type": "object",
      "required": [
        "style"
      ],
      "additionalProperties": false,
      "properties": {
        "colors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/color"
          },
          "description": "Gradient color stops."
        },
        "style": {
          "type": "string",
          "enum": [
            "linear",
            "radial",
            "clear"
          ],
          "description": "Gradient type."
        },
        "startPoint": {
          "$ref": "#/$defs/unitPoint",
          "description": "Linear gradient start point."
        },
        "endPoint": {
          "$ref": "#/$defs/unitPoint",
          "description": "Linear gradient end point."
        },
        "center": {
          "$ref": "#/$defs/unitPoint",
          "description": "Radial gradient center point."
        },
        "startRadius": {
          "type": "number",
          "minimum": 0,
          "description": "Radial gradient start radius."
        },
        "endRadius": {
          "type": "number",
          "minimum": 0,
          "description": "Radial gradient end radius."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "style": {
                "const": "linear"
              }
            }
          },
          "then": {
            "required": [
              "colors"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "style": {
                "const": "radial"
              }
            }
          },
          "then": {
            "required": [
              "colors"
            ]
          }
        }
      ]
    },
    "unitPoint": {
      "type": "string",
      "enum": [
        "top",
        "bottom",
        "leading",
        "trailing",
        "topLeading",
        "topTrailing",
        "bottomLeading",
        "bottomTrailing",
        "center"
      ],
      "description": "A point in the unit coordinate space."
    }
  }
}